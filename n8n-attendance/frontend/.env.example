# ===========================================
# N8N ATTENDANCE SYSTEM - FRONTEND ENVIRONMENT
# ===========================================

# API Configuration
REACT_APP_API_URL=https://your-backend-api-domain.com/api

# Authentication (if using Auth0 or similar)
REACT_APP_AUTH0_DOMAIN=your-auth0-domain.auth0.com
REACT_APP_AUTH0_CLIENT_ID=your-auth0-client-id
REACT_APP_AUTH0_AUDIENCE=https://your-backend-api-domain.com

# Application Configuration
REACT_APP_APP_NAME=N8N Attendance System
REACT_APP_VERSION=1.0.0
REACT_APP_ENVIRONMENT=production

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_ERROR_REPORTING=true
REACT_APP_ENABLE_PERFORMANCE_MONITORING=true

# External Services
# Sentry Error Tracking
REACT_APP_SENTRY_DSN=your-frontend-sentry-dsn

# Analytics (if using Google Analytics)
REACT_APP_GA_TRACKING_ID=GA-XXXXXXXXX

# WebSocket Configuration
REACT_APP_WEBSOCKET_URL=wss://your-backend-api-domain.com

# File Upload Configuration
REACT_APP_MAX_FILE_SIZE=10485760
REACT_APP_ALLOWED_FILE_TYPES=.pdf,.jpg,.jpeg,.png,.doc,.docx

# UI Configuration
REACT_APP_DEFAULT_THEME=light
REACT_APP_COMPANY_NAME=Your Company Name
REACT_APP_SUPPORT_EMAIL=support@your-domain.com

# Development/Debug (set to false in production)
REACT_APP_DEBUG_MODE=false
REACT_APP_MOCK_API=false