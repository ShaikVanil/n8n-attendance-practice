# ===========================================
# N8N ATTENDANCE SYSTEM - BACKEND ENVIRONMENT
# ===========================================

# Server Configuration
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://your-frontend-domain.com

# Database Configuration (Local PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=attendance
DB_USER=attendance_user
DB_PASSWORD=your-secure-database-password
DATABASE_URL=postgresql://attendance_user:your-secure-database-password@localhost:5432/attendance

# Authentication & Security
JWT_SECRET=your-super-secure-jwt-secret-key-min-32-chars
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# External Services
# SendGrid Email Service
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@your-domain.com
SENDGRID_FROM_NAME=N8N Attendance System

# Twilio SMS Service
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# File Storage (if using AWS S3)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# N8N Integration
N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud
N8N_API_KEY=your-n8n-api-key

# Security Headers & CORS
CORS_ORIGIN=https://your-frontend-domain.com
SECURE_COOKIES=true
SAME_SITE=strict

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging & Monitoring
LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn-url

# Session Configuration
SESSION_SECRET=your-session-secret-key
SESSION_MAX_AGE=86400000

# Feature Flags
ENABLE_AUDIT_LOGGING=true
ENABLE_DATA_RETENTION=true
ENABLE_NOTIFICATIONS=true