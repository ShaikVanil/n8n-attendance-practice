{
  "name": "attendance-backend",
  "version": "1.0.0",
  "description": "Backend for N8N Attendance System",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon src/server.ts",
    "build": "tsc --project tsconfig.prod.json",
    "build:dev": "tsc",
    "test": "jest",
    "test:unit": "jest --testPathPattern=__tests__/.*\\.test\\.(ts|js)$ --testPathIgnorePatterns=integration",
    "test:integration": "jest --testPathPattern=integration.*\\.test\\.(ts|js)$",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:performance": "npm run perf:load && npm run perf:stress",
    "perf:load": "artillery run performance/load-tests/api-load-test.yml",
    "perf:stress": "artillery run performance/stress-tests/stress-test.yml",
    "perf:benchmark": "node performance/scripts/benchmark.js",
    "perf:monitor": "node performance/scripts/monitor.js",
    "perf:report": "node performance/scripts/generate-report.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "migrate": "./scripts/db-migrate.sh",
    "seed": "ts-node src/database/seed.ts"
  },
  "dependencies": {
    "@sendgrid/mail": "^7.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-slow-down": "^1.6.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.4",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.3",
    "socket.io": "^4.7.2",
    "twilio": "^4.19.0",
    "uuid": "^9.0.0",
    "validator": "^13.11.0",
    "xlsx": "^0.18.5",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-slow-down": "^1.3.5",
    "@types/express-validator": "^3.0.0",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.5.0",
    "@types/node-cron": "^3.0.8",
    "@types/nodemailer": "^6.4.9",
    "@types/pdfkit": "^0.13.4",
    "@types/pg": "^8.10.2",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.2",
    "@types/validator": "^13.15.2",
    "@typescript-eslint/eslint-plugin": "^6.2.1",
    "@typescript-eslint/parser": "^6.2.1",
    "0x": "^5.5.0",
    "artillery": "^2.0.0",
    "autocannon": "^7.12.0",
    "clinic": "^12.0.0",
    "eslint": "^8.46.0",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "pidusage": "^3.0.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
