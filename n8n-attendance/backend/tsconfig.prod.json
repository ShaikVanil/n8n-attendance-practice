{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "sourceMap": false,
    "removeComments": true,
    "declaration": false,
    "declarationMap": false,
    "incremental": false,
    "tsBuildInfoFile": null
  },
  "exclude": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/test/**/*",
    "src/**/__tests__/**/*",
    "node_modules"
  ]
}